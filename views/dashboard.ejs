<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>In-Memory Database Ledger</title>
</head>
<body style="font-family: 'Segoe UI', Arial, sans-serif; background-color: #f8fafc; margin: 0; padding: 50px 20px;">

    <div style="max-width: 900px; margin: 0 auto; background: #ffffff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
        
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 25px;">
            <h2 style="margin: 0; color: #0f172a;">🗄️ Server-Side Temporary Storage</h2>
            <a href="/" style="text-decoration: none; padding: 8px 16px; background-color: #64748b; color: #fff; font-size: 0.9rem; font-weight: 600; border-radius: 6px;">+ New Entry</a>
        </div>

        <% if (records.length === 0) { %>
            <div style="text-align: center; padding: 40px; color: #94a3b8; font-size: 1.1rem;">
                No validated entries detected in transient storage. Submit the registration form to populate this layout matrix.
            </div>
        <% } else { %>
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                    <thead>
                        <tr style="background-color: #f1f5f9; color: #475569; border-bottom: 2px solid #cbd5e1;">
                            <th style="padding: 12px 15px;">UID Reference</th>
                            <th style="padding: 12px 15px;">Candidate Name</th>
                            <th style="padding: 12px 15px;">Email Domain</th>
                            <th style="padding: 12px 15px;">Contact Info</th>
                            <th style="padding: 12px 15px;">Specialization</th>
                            <th style="padding: 12px 15px;">Skill Tier</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% records.forEach((item, index) => { %>
                            <tr <% if (index % 2 === 0) { %> style="border-bottom: 1px solid #e2e8f0; background-color: #ffffff; color: #334155;" <% } else { %> style="border-bottom: 1px solid #e2e8f0; background-color: #f8fafc; color: #334155;" <% } %> >
                                <td style="padding: 12px 15px; font-family: monospace; font-weight: bold; color: #2563eb;"><%= item.id %></td>
                                <td style="padding: 12px 15px; font-weight: 600;"><%= item.fullName %></td>
                                <td style="padding: 12px 15px;"><%= item.email %></td>
                                <td style="padding: 12px 15px;"><%= item.phone %></td>
                                <td style="padding: 12px 15px; color: #0ea5e9; font-weight: 500;"><%= item.course %></td>
                                <td style="padding: 12px 15px;">
                                    <% if (item.experience === 'Advanced') { %>
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; background-color: #dcfce7; color: #15803d;">
                                            <%= item.experience %>
                                        </span>
                                    <% } else if (item.experience === 'Intermediate') { %>
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; background-color: #fef9c3; color: #a16207;">
                                            <%= item.experience %>
                                        </span>
                                    <% } else { %>
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; background-color: #fee2e2; color: #b91c1c;">
                                            <%= item.experience %>
                                        </span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

</body>
</html>